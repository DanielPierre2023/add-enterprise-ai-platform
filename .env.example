# Public site URL (used for canonical URLs, OG tags, sitemap base)
NEXT_PUBLIC_SITE_URL=https://add-individual-solutions.com

# Email (Resend) - PRIVATE
RESEND_API_KEY=replace_me

# Contact routing
CONTACT_EMAIL=contact@add-individual-solutions.com
INFO_EMAIL=info@add-individual-solutions.com

# Optional: Supabase (public client keys are OK as NEXT_PUBLIC)
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Optional: Supabase server-only secret (NEVER prefix with NEXT_PUBLIC)
# SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
